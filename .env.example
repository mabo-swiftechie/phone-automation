# ============================================
# AI電話自動化 — 環境変数（コピーして .env にリネーム）
# ============================================
# 使い方:
#   cp .env.example .env
#   .env の値を実際のキーに書き換える

# OpenAI（必須 — メール生成・返信解析）
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Retell AI（電話確認を使う場合）
RETELL_API_KEY=key_xxxxxxxxxxxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxxx
