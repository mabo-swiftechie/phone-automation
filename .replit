[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "pip install . && streamlit run app/ui.py --server.headless true --server.port 8501 --browser.gatherUsageStats false"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8501
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
